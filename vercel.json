{
  "crons": [
    {
      "path": "/api/cron-daily-report",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    { "source": "/qr-template.html", "destination": "/qr-template.html" },
    {
      "source": "/r/:slug",
      "missing": [{ "type": "query", "key": "go" }],
      "destination": "/api/r-og?slug=:slug"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
