# Copiar este archivo a .env y completar con los valores reales
# (Project Settings > API en tu proyecto de Supabase)

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# ID del venue activo (ver tabla "venues", se crea con el seed)
VITE_VENUE_ID=00000000-0000-0000-0000-000000000001

# Opcional. Si lo definís, el cliente puede elegir "Transferencia" como
# forma de pago: ve este alias, transfiere, y sube una foto del
# comprobante. El cajero la revisa en el panel admin antes de confirmar
# el pedido. Si no lo definís, solo aparecen "Efectivo" y "Tarjeta"
# (pago en persona, el mozo lo marca como cobrado desde el panel admin).
VITE_TRANSFER_ALIAS=mirestaurante.mp

